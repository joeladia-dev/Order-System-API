# Copy to a local .env (or set user env vars) and provide real values.

# Shared auth settings
AUTH_ISSUER=OrderSystem.Auth
AUTH_AUDIENCE=OrderSystem.Api
ORDER_SYSTEM_JWT_SIGNING_KEY=<set-long-random-secret>

# Google OAuth
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:8086/api/auth/oauth/callback/google

# Per-service auth rollout toggles
ORDER_AUTH_ENABLED=true
PRODUCT_AUTH_ENABLED=true
INVENTORY_AUTH_ENABLED=false
PAYMENT_AUTH_ENABLED=false
SHIPPING_AUTH_ENABLED=false
