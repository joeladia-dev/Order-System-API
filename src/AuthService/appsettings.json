{
  "ConnectionStrings": {
    "AuthDb": "Data Source=auth.db"
  },
  "Auth": {
    "Issuer": "OrderSystem.Auth",
    "Audience": "OrderSystem.Api",
    "SigningKey": "",
    "CodePepper": "dev-otp-pepper",
    "AccessTokenMinutes": 60,
    "CodeExpiryMinutes": 10,
    "ResendCooldownSeconds": 30,
    "MaxVerifyAttempts": 5
  },
  "OAuth": {
    "StateExpiryMinutes": 10,
    "Providers": {
      "google": {
        "Enabled": false,
        "ClientId": "",
        "ClientSecret": "",
        "AuthorizationEndpoint": "https://accounts.google.com/o/oauth2/v2/auth",
        "TokenEndpoint": "https://oauth2.googleapis.com/token",
        "UserInfoEndpoint": "https://openidconnect.googleapis.com/v1/userinfo",
        "RedirectUri": "http://localhost:8086/api/auth/oauth/callback/google",
        "Scope": "openid profile email",
        "Prompt": "select_account",
        "EmailClaim": "email",
        "SubjectClaim": "sub"
      },
      "microsoft": {
        "Enabled": false,
        "ClientId": "",
        "ClientSecret": "",
        "AuthorizationEndpoint": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
        "TokenEndpoint": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
        "UserInfoEndpoint": "https://graph.microsoft.com/oidc/userinfo",
        "RedirectUri": "http://localhost:8086/api/auth/oauth/callback/microsoft",
        "Scope": "openid profile email",
        "Prompt": "select_account",
        "EmailClaim": "email",
        "SubjectClaim": "sub"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
